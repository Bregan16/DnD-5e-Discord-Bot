{
  "name": "discord-getting-started",
  "private": true,
  "version": "1.0.0",
  "description": "Discord example app",
  "main": "dist/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node .",
    "start:old": "node src/app.ts",
    "register": "node src/commands.js",
    "dev:old": "nodemon src/app.ts",
    "pretest": "npm run build",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "author": "Shay DeWael",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.26.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.0",
    "tsx": "^4.23.0"
  }
}
